---
import { renderDotVersionLabel } from '../ui/dotVersionLabel.js';

const { i18n } = Astro.props;
const t = (k) => i18n.t(k);
const currentYear = new Date().getFullYear();

const socialLinks = [
  { src: '/icons/social/github.svg', url: 'https://github.com/W-Mirshod', label: 'GitHub' },
  { src: '/icons/social/linkedin.svg', url: 'https://linkedin.com/in/wmirshod', label: 'LinkedIn' },
  { src: '/icons/social/telegram.svg', url: 'https://t.me/w_mirshod', label: 'Telegram' },
  {
    src: '/icons/social/instagram.svg',
    url: 'https://www.instagram.com/wmirshod/?igsh=czRpZ3d5dzBxa2o3&utm_source=qr',
    label: 'Instagram',
  },
];
---

<footer id="contact" class="liquid-section section-accent-glow py-16 px-4 bg-bg-secondary/20 border-t border-white/20">
  <div class="max-w-4xl mx-auto">
    <header class="text-center mb-12">
      <h2 class="text-3xl font-light liquid-title mb-3 tracking-wide animate-fadeInUp">{t('footer.connect.title')}</h2>
      <div class="liquid-divider mx-auto animate-fadeInUp delay-100"></div>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <div class="liquid-panel rounded-xl p-6 border border-white/20">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg liquid-icon-shell flex items-center justify-center">
            <img src="/icons/contact/mail.svg" alt="" class="w-5 h-5" width="20" height="20" />
          </div>
          <h3 class="text-lg font-semibold text-white">{t('footer.connect.contactInfo')}</h3>
        </div>
        <div class="space-y-3">
          <a
            href="mailto:wmirshod@gmail.com"
            class="flex items-center gap-3 p-3 rounded-lg bg-white/10 border border-white/20 hover:bg-white/20 hover:border-white/35 transition-all duration-300"
          >
            <div class="w-8 h-8 rounded-md bg-white/10 flex items-center justify-center">
              <img src="/icons/contact/mail.svg" alt="" class="w-5 h-5" width="20" height="20" />
            </div>
            <div>
              <div class="text-sm font-medium text-white">{t('footer.connect.email')}</div>
              <div class="text-xs text-white/70">wmirshod@gmail.com</div>
            </div>
          </a>
          <a
            href="tel:+998907126437"
            class="flex items-center gap-3 p-3 rounded-lg bg-white/10 border border-white/20 hover:bg-white/20 hover:border-white/35 transition-all duration-300"
          >
            <div class="w-8 h-8 rounded-md bg-white/10 flex items-center justify-center">
              <img src="/icons/contact/phone.svg" alt="" class="w-5 h-5" width="20" height="20" />
            </div>
            <div>
              <div class="text-sm font-medium text-white">{t('footer.connect.phone')}</div>
              <div class="text-xs text-white/70">+998 90 712 64 37</div>
            </div>
          </a>
          <a
            href="https://maps.google.com/?q=Tashkent, Uzbekistan"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 p-3 rounded-lg bg-white/10 border border-white/20 hover:bg-white/20 hover:border-white/35 transition-all duration-300"
          >
            <div class="w-8 h-8 rounded-md bg-white/10 flex items-center justify-center">
              <img src="/icons/contact/map-pin.svg" alt="" class="w-5 h-5" width="20" height="20" />
            </div>
            <div>
              <div class="text-sm font-medium text-white">{t('footer.connect.location')}</div>
              <div class="text-xs text-white/70">Tashkent, Uzbekistan</div>
            </div>
          </a>
        </div>
      </div>
      <div class="liquid-panel rounded-xl p-6 border border-white/20">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg liquid-icon-shell flex items-center justify-center">
            <img src="/icons/contact/share.svg" alt="" class="w-5 h-5" width="20" height="20" />
          </div>
          <h3 class="text-lg font-semibold text-white">{t('footer.connect.socialMedia')}</h3>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-3 rounded-lg bg-white/10 border border-white/20 hover:bg-white/20 hover:border-white/35 transition-all duration-300"
              >
                <div class="w-8 h-8 rounded-md liquid-icon-shell flex items-center justify-center">
                  <img src={link.src} alt="" class="w-5 h-5" width="20" height="20" />
                </div>
                <div class="text-sm font-medium text-white">{link.label}</div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
    <div class="text-center pt-8 border-t border-white/20">
      <div class="page-version-mark mb-5" aria-label="Version 4.3">
        <Fragment set:html={renderDotVersionLabel('VERSION 4.3')} />
      </div>
      <p class="text-sm text-white/70">© 2023-{currentYear} W-Mirshod. All rights reserved.</p>
    </div>
  </div>
</footer>
